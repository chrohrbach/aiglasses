# =============================================================================
# Rokid side
# =============================================================================
# The AK you paste into the Lingzhu UI when registering the custom agent.
# Rokid will send it back as `Authorization: Bearer <AK>`.
# Generate with: openssl rand -hex 24
ROKID_AK=replace-me-with-a-long-random-string

# Callback endpoint Rokid expects when WE push messages back to the glasses.
# Spec gives only the path /metis/callback/message — confirm the host on the
# Lingzhu doc/dashboard before enabling. Leave empty to disable /push.
ROKID_CALLBACK_URL=
# sk token generated once at https://account-web.rokid.com/token
ROKID_SK_TOKEN=

# =============================================================================
# OpenWebUI — used for the "full" routing path (with MCP tools fanout)
# =============================================================================
OPENWEBUI_URL=http://openwebui:8080
# API key for the dedicated "glasses" OpenWebUI user. Create in Admin Panel →
# Users, sign in as that user, Settings → Account → API Key → Generate.
OPENWEBUI_API_KEY=sk-replace-me
# Model the OpenWebUI path calls. purpose-tool-calling routes to
# infomaniak-gemma4 (Swiss, fast, tool-friendly).
OPENWEBUI_MODEL=purpose-tool-calling
OPENWEBUI_TEMPERATURE=0.4

# =============================================================================
# LiteLLM — used for the "fast" and "vision" routing paths (direct, no MCP)
# =============================================================================
LITELLM_URL=http://litellm:4000/v1
LITELLM_API_KEY=sk-anything
LITELLM_TEMPERATURE=0.4
# Fast model for short voice queries (no tools, no image). Mistral Ministral
# 3 14B via Infomaniak — sovereign Swiss, sub-second TTFT on short prompts.
ROKID_FAST_MODEL=infomaniak-ministral
# Vision model when image_url is present. Currently OpenRouter (no Swiss
# vision model in litellm.yaml yet).
ROKID_VISION_MODEL=purpose-vision
# Char length below which a text-only request is eligible for the fast path.
ROKID_FAST_MAX_CHARS=120

# =============================================================================
# Photo cache
# =============================================================================
# Public URL the model uses to re-fetch a cached photo. Internal default works
# inside mcp-network. If you want a photo URL that survives outside the cluster
# (e.g. embedded in an email), set this to https://glasses.rohrbach.app instead.
PHOTOS_PUBLIC_URL=http://rokid-shim:8000
PHOTO_RETENTION_HOURS=48
PHOTO_MAX_BYTES=10485760
# When true (default), incoming Rokid camera URLs are inlined as
# data:image/...;base64,... in the LLM request — works with cloud backends
# like OpenRouter that can't reach internal URLs. The disk copy still lives at
# PHOTO_CACHE_DIR for downstream tool re-use. Set to false to use public URLs
# instead (only viable when PHOTOS_PUBLIC_URL is internet-reachable).
PHOTO_INLINE_BASE64=true

# =============================================================================
# /push endpoint protection
# =============================================================================
# If set, callers of POST /push must send X-Push-Secret with this value.
# Leave empty for unauthenticated push (intra-mcp-network only).
PUSH_SHARED_SECRET=

# =============================================================================
# Misc
# =============================================================================
LOG_LEVEL=INFO

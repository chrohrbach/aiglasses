# Rokid Lingzhu — the AK you generate and paste into Lingzhu when registering
# the custom agent. Rokid will send this back as `Authorization: Bearer <AK>`.
# Generate a random string (e.g. `openssl rand -hex 24`).
ROKID_AK=replace-me-with-a-long-random-string

# OpenWebUI backend. Inside the mcp-network the openwebui service is reachable
# as http://openwebui:8080. From outside the docker network use the public URL.
OPENWEBUI_URL=http://openwebui:8080

# OpenWebUI API key for the "glasses" user account. Create the user in OpenWebUI
# Admin Panel, sign in, go to Settings → Account → API Key → Generate.
OPENWEBUI_API_KEY=sk-replace-me

# OpenWebUI model id to call. Must be vision-capable if you want camera frames
# to work. Examples: anthropic/claude-sonnet-4-6, openai/gpt-4o, gemini/2.0-flash.
OPENWEBUI_MODEL=anthropic/claude-sonnet-4-6

# Optional: model temperature. Lower is more deterministic for the tool_call
# fenced-JSON pattern.
OPENWEBUI_TEMPERATURE=0.4

# Optional: log level for the shim (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
